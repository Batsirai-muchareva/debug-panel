{
    "name": "debug-panel",
    "$schema": "node_modules/nx/schemas/project-schema.json",
    "targets": {
        "local-registry": {
            "executor": "@nx/js:verdaccio",
            "options": {
                "port": 4873,
                "config": ".verdaccio/config.yml",
                "storage": "tmp/local-registry/storage"
            }
        },
        "serve-all": {
            "executor": "nx:run-commands",
            "options": {
                "commands": [
                    "nx serve dev-panel",
                    "nx serve server-panel",
                    "nx serve ws-server"
                ],
                "parallel": true
            }
        },
        "build": {
            "executor": "nx:run-commands",
            "options": {
                "command": "nx run-many --target=build --all"
            },
            "outputs": ["{workspaceRoot}/build"]
        },
        "build-production": {
            "executor": "nx:run-commands",
            "options": {
                "commands": [
                    "nx run-many --target=build --all --exclude=debug-panel",
                    "grunt production"
                ],
                "parallel": false
            },
            "outputs": ["{workspaceRoot}/zip-builds"]
        }
    }
}
