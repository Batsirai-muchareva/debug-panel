{
    "name": "@debug-panel/storage",
    "$schema": "../../node_modules/nx/schemas/project-schema.json",
    "sourceRoot": "libs/storage/src",
    "projectType": "library",
    "tags": ["storage"],
    "// targets": "to see all targets run: nx show project @debug-panel/storage --web",
    "targets": {
        "build": {
            "executor": "nx:run-commands",
            "options": {
                "cwd": "libs/storage",
                "command": "vite build"
            },
            "outputs": ["{workspaceRoot}/dist/libs/storage"]
        }
    }
}
